# =====================================================
# Spider 模块 .gitignore
# =====================================================

# 环境变量（包含数据库密码）
.env
.env.local
.env.*.local

# 虚拟环境
venv/
env/

# Python缓存
__pycache__/
*.py[cod]
*.pyo

# 日志文件
logs/*.log

# 断点续爬文件
data/*_checkpoint.json

# 临时数据
*.tmp
*.bak

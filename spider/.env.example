# =====================================================
# 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# =====================================================

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=gaokao_ai

# 爬虫配置
SPIDER_TIMEOUT=30
SPIDER_MAX_RETRIES=3
SPIDER_MAX_WORKERS=5
SPIDER_REQUEST_DELAY=1.0
SPIDER_LOG_LEVEL=INFO
